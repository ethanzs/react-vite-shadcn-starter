# Environment variables
# Copy this file to `.env` and fill in values for local development.
# All variables must be prefixed with VITE_ to be exposed to the client at build time.

# Production API host. Used as `https://$VITE_API_URL` when VITE_ENVIRONMENT is not "development".
VITE_API_URL=api.example.com

# When set to "development" (case-insensitive), API calls go to http://localhost:8443
# instead of VITE_API_URL. Anything else (or unset) is treated as production.
VITE_ENVIRONMENT=development

# When "true", `GetMfaState` and `GetUsersMe` return hardcoded fake responses so the
# authenticated UI renders without a backend, and demo group/org data from
# src/lib/fixtures.ts is shown. Other API calls will still fail — sample data only.
VITE_SIMULATE_AUTH=false

# Minimum log level for src/lib/logger.ts. One of: debug, info, warn, error, silent.
# Defaults: "debug" in dev (npm run dev), "warn" in production builds.
# VITE_LOG_LEVEL=debug
